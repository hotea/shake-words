# Backend configuration
# Options: "local" | "supabase" | "rest"
# "local" = localStorage only (no auth needed)
# "supabase" = Supabase cloud storage + auth
NEXT_PUBLIC_BACKEND_TYPE=local

# Supabase (when BACKEND_TYPE=supabase)
# Get these from your Supabase project: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Custom REST API (when BACKEND_TYPE=rest)
NEXT_PUBLIC_API_BASE_URL=

# ============================================================
# Supabase Setup Guide
# ============================================================
# 1. Create a project at https://supabase.com
# 2. Run these SQL statements in the SQL Editor:
#
#    CREATE TABLE learning_records (
#      id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
#      user_id UUID REFERENCES auth.users(id) ON DELETE CASCADE NOT NULL,
#      word_id TEXT NOT NULL,
#      book_id TEXT NOT NULL,
#      is_correct BOOLEAN NOT NULL,
#      response_ms INTEGER NOT NULL,
#      gesture TEXT NOT NULL,
#      created_at TIMESTAMPTZ DEFAULT now() NOT NULL
#    );
#
#    CREATE TABLE word_progress (
#      user_id UUID REFERENCES auth.users(id) ON DELETE CASCADE NOT NULL,
#      word_id TEXT NOT NULL,
#      book_id TEXT NOT NULL,
#      mastery INTEGER DEFAULT 0 NOT NULL,
#      next_review TIMESTAMPTZ DEFAULT now() NOT NULL,
#      updated_at TIMESTAMPTZ DEFAULT now() NOT NULL,
#      PRIMARY KEY (user_id, word_id)
#    );
#
#    -- RLS policies (users can only access their own data)
#    ALTER TABLE learning_records ENABLE ROW LEVEL SECURITY;
#    ALTER TABLE word_progress ENABLE ROW LEVEL SECURITY;
#
#    CREATE POLICY "Users read own records" ON learning_records
#      FOR SELECT USING (auth.uid() = user_id);
#    CREATE POLICY "Users insert own records" ON learning_records
#      FOR INSERT WITH CHECK (auth.uid() = user_id);
#
#    CREATE POLICY "Users read own progress" ON word_progress
#      FOR SELECT USING (auth.uid() = user_id);
#    CREATE POLICY "Users upsert own progress" ON word_progress
#      FOR ALL USING (auth.uid() = user_id);
#
#    -- Indexes
#    CREATE INDEX idx_records_user_book ON learning_records(user_id, book_id);
#    CREATE INDEX idx_records_created ON learning_records(created_at DESC);
#
# 3. Enable GitHub and/or Google OAuth in Authentication > Providers
# 4. Set NEXT_PUBLIC_BACKEND_TYPE=supabase and fill in the URL + anon key above
